# Secrets only — app configuration lives in config/active/operator.yaml.
# These env vars are referenced via ${VAR} syntax in operator.yaml.
#
# Copy this file to .env and fill in the values, or export them in your shell.

# --- Secrets ---

FRANK_GITHUB_TOKEN=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
REVIEW_AGENT_SMTP_PASS=

# --- Django infrastructure ---

# DJANGO_SECRET_KEY=change-me-to-a-random-string
DJANGO_DEBUG=true
# DJANGO_ALLOWED_HOSTS=*
# DATABASE_URL=postgres://user:pass@localhost:5432/frank
