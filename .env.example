# franktheunicorn environment configuration
# Copy this file to .env and fill in the values.
#
#   cp .env.example .env

# --- Django ---

# Set a real secret key in production.
# DJANGO_SECRET_KEY=change-me-to-a-random-string

# Enable debug mode (true in development, false in production).
DJANGO_DEBUG=true

# Comma-separated list of allowed hostnames. "*" allows all.
# DJANGO_ALLOWED_HOSTS=*

# --- franktheunicorn app ---

# Directory for persistent state (SQLite database, etc.).
# FRANK_DATA_DIR=./data

# GitHub personal access token (required for real PR ingestion).
FRANK_GITHUB_TOKEN=

# LLM API keys — set the one matching your configured provider.
# See operator.yaml for provider selection.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Enable mock/demo mode with fixture data (no tokens needed).
FRANK_MOCK_MODE=true

# Path to operator config YAML.
# FRANK_OPERATOR_CONFIG=config/examples/operator.yaml

# Directory containing per-project YAML configs.
# FRANK_PROJECTS_DIR=config/examples/projects

# Directory containing fixture JSON for mock mode.
# FRANK_FIXTURES_DIR=config/fixtures

# Worker polling interval in seconds.
# FRANK_POLL_INTERVAL=300

# --- Database ---

# Optional: use Postgres instead of SQLite (default).
# DATABASE_URL=postgres://user:pass@localhost:5432/frank

# --- Email digest (optional) ---

REVIEW_AGENT_SMTP_HOST=
REVIEW_AGENT_SMTP_PORT=587
REVIEW_AGENT_SMTP_USER=
REVIEW_AGENT_SMTP_PASS=
REVIEW_AGENT_EMAIL_FROM=
